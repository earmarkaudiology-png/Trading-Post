  const esc = (s) => String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');

  const attrEsc = esc;

  const panel = (title, body) =>
    '<div style="background:#2a2118;border:1px solid #5b4632;border-radius:10px;padding:10px;max-width:760px;color:#f7f1e6;box-shadow:0 2px 6px rgba(0,0,0,0.35);">' +

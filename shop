  const magicRequestProfile = (store, item) => {
    const gp = magicBasePriceForStore(store, item) / 100;
    const tier = String(item.tier || 'common').toLowerCase();
    let chance = ({ everyday: 95, common: 90, uncommon: 75, scarce: 55, rare: 30, very_rare: 10 }[tier] || 50);
    if (gp > 10000) chance = Math.min(chance, 2);
    else if (gp > 5000) chance = Math.min(chance, 5);
    else if (gp > 3000) chance = Math.min(chance, 5);
    else if (gp > 2000) chance -= 15;
    else if (gp > 1000) chance -= 10;
    else if (gp > 500) chance -= 5;
    if (store.settlement === 'city') chance += 10;
    else if (store.settlement === 'town') chance += 5;
    else if (store.settlement === 'village') chance -= 5;
    else if (store.settlement === 'hamlet') chance -= 10;
    if (store.size === 'large') chance += 5;
    else if (store.size === 'small') chance -= 5;
    if (store.tags.indexOf('market') !== -1) chance += 5;
    if (store.tags.indexOf('wealthy') !== -1) chance += 5;
    if (store.tags.indexOf('port') !== -1 || store.tags.indexOf('river') !== -1) chance += 5;
    if (store.tags.indexOf('remote') !== -1) chance -= 10;
    if (store.tags.indexOf('frontier') !== -1) chance -= 10;
    if (store.tags.indexOf('poor') !== -1) chance -= 10;
    if (store.focus === 'adventurer' && ['potions','scrolls','armor','weapons','rings','rods_wands','wondrous'].indexOf(item.category) !== -1) chance += 5;
    chance = clamp(chance, 1, 95);

    let etaMin = 1, etaMax = 6;
    if (tier === 'uncommon') { etaMin = 3; etaMax = 10; }
    else if (tier === 'scarce') { etaMin = 7; etaMax = 20; }
    else if (tier === 'rare') { etaMin = 14; etaMax = 45; }
    else if (tier === 'very_rare') { etaMin = 30; etaMax = 120; }
    if (gp > 3000) { etaMin += 14; etaMax += 45; }
    else if (gp > 1000) { etaMin += 7; etaMax += 21; }
    else if (gp > 500) { etaMin += 3; etaMax += 10; }
    if (store.settlement === 'town') { etaMin += 2; etaMax += 6; }
    else if (store.settlement === 'village') { etaMin += 7; etaMax += 14; }
    else if (store.settlement === 'hamlet') { etaMin += 14; etaMax += 30; }
    if (store.size === 'small') { etaMin += 3; etaMax += 7; }
    if (store.tags.indexOf('market') !== -1 || store.tags.indexOf('wealthy') !== -1) { etaMin = Math.max(1, etaMin - 1); etaMax = Math.max(etaMin, etaMax - 3); }
    if (store.tags.indexOf('port') !== -1 || store.tags.indexOf('river') !== -1) { etaMin = Math.max(1, etaMin - 1); etaMax = Math.max(etaMin, etaMax - 2); }

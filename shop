    }
    if (store.type === 'outfitter' && (item.category === 'misc' || item.category === 'provisions')) max += 2;
    if (store.type === 'trading_post' && (item.category === 'misc' || item.category === 'provisions' || item.category === 'clothing')) max += 2;
    if (store.type === 'stable' && (item.category === 'livestock' || item.category === 'tack')) max += 2;

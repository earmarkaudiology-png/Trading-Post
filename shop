      if (mode !== 'stock') {
        if ((line.qty || 0) > 0) kept.push(line);
        return;
      }
      if (store.id !== 'baseline' && !isUnlimitedKey(line.itemKey)) {
        if (line.isTrinket) {
          const tr = (store.trinkets || []).find(t => t.key === line.itemKey);
          const live = tr ? parseInt(tr.qty || 0, 10) : 0;
          if (live <= 0) {
            problems.push(line.name + ' is now out of stock and was removed from your cart.');
            return;
          }
          if ((line.qty || 0) > live) {
            problems.push(line.name + ' was reduced from ' + line.qty + ' to ' + live + ' due to current stock.');
            line.qty = live;
            line.totalCp = line.qty * line.unitCp;
          }
        } else {
          const live = parseInt(store.stock[line.itemKey] || 0, 10);
          if (line.stockDetailId) {
            const detailLive = getMagicStockDetails(store, line.itemKey).some(entry => entry.id === line.stockDetailId);
            if (!detailLive) {
              problems.push(line.name + ' is now out of stock and was removed from your cart.');
              return;
            }
          }
          if (live <= 0) {
            problems.push(line.name + ' is now out of stock and was removed from your cart.');
            return;
          }
          if (!line.stockDetailId && (line.qty || 0) > live) {
            problems.push(line.name + ' was reduced from ' + line.qty + ' to ' + live + ' due to current stock.');
            line.qty = live;
            line.totalCp = line.qty * line.unitCp;
          }
        }
      }
      if ((line.qty || 0) > 0) kept.push(line);
    });
    cart.lines = kept;
    return problems;
  };

    const checkout = (msg) => {
    const cart = getCart(msg.playerid);
    if (!cart.lines.length) return info(msg.playerid, 'Shop Error', ['Your cart is empty.']);
    const sel = getSelectedCharacter(msg);
    if (!sel || sel.characterId !== cart.characterId) return info(msg.playerid, 'Shop Error', ['Select the buyer token for this cart before checking out.']);
    const store = getStore(cart.storeId);
    if (!store) return info(msg.playerid, 'Shop Error', ['The source store no longer exists.']);

    const stockProblems = validateCartAgainstLiveStock(store, cart);
    if (!cart.lines.length) {
      const lines = stockProblems.length ? stockProblems.slice() : ['Your cart no longer has any available items.'];
      lines.push(btn('Return to Store', '!shop-open ' + cart.storeId, 120) + ' ' + btn('Main Menu', '!shop-menu', 90));
      clearCart(msg.playerid);
      return info(msg.playerid, 'Cart Updated', lines);
    }

    const fitProblems = [];
    cart.lines.forEach((line, idx) => {
      if ((line.cartMode || 'stock') !== 'stock') return;
      if (!lineNeedsArmorFit(line)) return;
      if (!line.fitChecked) fitProblems.push((idx + 1) + '. ' + line.name + ' needs a fit roll before checkout.');
      else if (!line.fitOk) fitProblems.push((idx + 1) + '. ' + line.name + ' does not fit (' + (line.fitResult || 'failed') + ').');
    });
    if (fitProblems.length) {
      const lines = stockProblems.slice().concat(fitProblems);
      lines.push(btn('View Cart', '!shop-cart', 100));
      return info(msg.playerid, 'Shop Error', lines);
    }

    let totalDueNow = 0;
    cart.lines.forEach(line => { totalDueNow += Math.max(1, Math.round(line.totalCp !== undefined ? line.totalCp : cartLineTotal(line))); });

    const purse = getMoneyCp(sel.characterId);
    if (purse < totalDueNow) {
      const lines = stockProblems.slice();
      lines.push('You need ' + cpToDisplay(totalDueNow) + ' but only have ' + cpToDisplay(purse) + '.');
      lines.push(btn('View Cart', '!shop-cart', 100));
      return info(msg.playerid, 'Shop Error', lines);
    }

    if (!spendMoneyCp(sel.characterId, totalDueNow)) {
      return info(msg.playerid, 'Shop Error', [
        'Payment could not be completed from available Gold, Silver, and Copper.',
        btn('View Cart', '!shop-cart', 100)
      ]);
    }

    const receipt = stockProblems.slice();
    const gmLines = [];
    let immediateTotal = 0;
    let requestDepositTotal = 0;
    let orderDepositTotal = 0;

    cart.lines.forEach(line => {
      const mode = line.cartMode || 'stock';
      const item = byKey[line.itemKey];
      if (mode === 'stock') {
        const lineTotal = line.totalCp !== undefined ? line.totalCp : cartLineTotal(line);
        immediateTotal += lineTotal;
        let itemName = line.name;
        const traits = getHorseTraitStringForStore(store, line.itemKey);
        if (traits) itemName += ' (' + traits + ')';
        addEquipmentRow(sel.characterId, itemName, line.qty, line.weight || 0, cpToDisplay(line.unitCp));
        receipt.push(itemName + (line.qty > 1 ? ' x' + line.qty : '') + ' — ' + cpToDisplay(lineTotal));
        if (store.id !== 'baseline' && !isUnlimitedKey(line.itemKey)) {
          if (line.isTrinket) {
            const tr = (store.trinkets || []).find(t => t.key === line.itemKey);
            if (tr) tr.qty = Math.max(0, tr.qty - line.qty);
          } else {
            if (line.stockDetailId) popMagicStockDetail(store, line.itemKey, line.stockDetailId);
            store.stock[line.itemKey] = Math.max(0, (store.stock[line.itemKey] || 0) - line.qty);
          }
        }
        return;
      }

      if (mode === 'request') {
        requestDepositTotal += line.totalCp;
        for (let i = 0; i < line.qty; i++) {
          const req = makeMagicHiddenRequest(store, item);
          const orderId = 'MS' + (state[SCRIPT].nextOrderId++);
          const orderItemName = isSpellScrollItem(item) ? rollSpellScrollLabelForItem(item) : displayMagicItemName(item);
          state[SCRIPT].orders.push({
            id: orderId,
            playerid: msg.playerid,
            characterId: sel.characterId,
            buyerName: sel.character.get('name') || 'Buyer',
            storeId: store.id,
            storeName: store.name,
            itemKey: item.key,
            itemName: orderItemName,
            category: item.category,
            totalCp: req.baseCp,
            depositCp: req.depositCp,
            balanceCp: req.balanceCp,
            placedDay: state[SCRIPT].day,
            arrivalDay: req.arrivalDay,
            resolutionDay: req.resolutionDay,
            etaKnown: req.etaKnown,
            etaMin: req.etaMin,
            etaMax: req.etaMax,
            deliveryCp: 0,
            servicePct: 0,
            mode: 'request',
            status: 'pending',
            willArrive: req.willArrive,
            chancePct: req.chance
          });
          gmLines.push(orderId + ' — ' + orderItemName + ' for ' + (sel.character.get('name') || 'Buyer') + ' at ' + store.name + ' — ' + (req.willArrive ? ('ARRIVES day ' + req.arrivalDay) : ('FAILED by day ' + req.resolutionDay)) + ' — chance ' + req.chance + '%');
        }
        receipt.push(item.name + (line.qty > 1 ? ' x' + line.qty : '') + ' — request deposit ' + cpToDisplay(line.totalCp));
        return;
      }

      if (mode === 'order') {
        orderDepositTotal += line.totalCp;
        for (let i = 0; i < line.qty; i++) {
          const quote = makeMagicOrderQuote(store, item);
          const orderId = 'MO' + (state[SCRIPT].nextOrderId++);
          const orderItemName = isSpellScrollItem(item) ? rollSpellScrollLabelForItem(item) : displayMagicItemName(item);
          state[SCRIPT].orders.push({
            id: orderId,
            playerid: msg.playerid,
            characterId: sel.characterId,
            buyerName: sel.character.get('name') || 'Buyer',
            storeId: store.id,
            storeName: store.name,
            itemKey: item.key,
            itemName: orderItemName,
            category: item.category,
            totalCp: quote.totalCp,
            depositCp: quote.depositCp,
            balanceCp: quote.balanceCp,
            placedDay: state[SCRIPT].day,
            readyDay: quote.readyDay,
            deliveryCp: quote.deliveryCp,
            servicePct: quote.servicePct,
            mode: item.mode || 'order',
            status: 'pending',
            willArrive: true
          });
        }
        receipt.push(item.name + (line.qty > 1 ? ' x' + line.qty : '') + ' — order deposit ' + cpToDisplay(line.totalCp));
      }
    });

    receipt.push('');
    receipt.push('Immediate purchases paid: ' + cpToDisplay(immediateTotal));
    if (requestDepositTotal) receipt.push('Request deposits paid: ' + cpToDisplay(requestDepositTotal));
    if (orderDepositTotal) receipt.push('Order deposits paid: ' + cpToDisplay(orderDepositTotal));
    receipt.push('Spent now: ' + cpToDisplay(totalDueNow));
    receipt.push(btn('Main Menu', '!shop-menu', 90) + ' ' + btn('Return to Store', '!shop-open ' + cart.storeId, 120) + ' ' + btn('Orders', '!shop-orders', 90));
    clearCart(msg.playerid);
    if (gmLines.length) gmInfo('Magic Request Outcomes', gmLines);
    info(msg.playerid, 'Checkout Complete', receipt);
  };

    const needsMonthlyRestock = (item) => {
    if (!item) return false;
    if (isMagicItem(item)) {
      if (item.mode === 'order' || item.mode === 'craft') return true;
      if (item.category === 'components' || item.category === 'books') return false;
      return item.priceCp >= 30000;
    }
    if (item.category === 'armor' || item.category === 'weapons') return true;
    if (isHorseItemKey(item.key)) return true;
    if (item.priceCp >= 2500) return true;
    if (item.tier === 'scarce' || item.tier === 'rare') return true;
    return false;
  };

    const restockAmount = (missing, itemOrTier, store) => {
    if (missing <= 0) return 0;
    if (store && isMagicStore(store)) {
      const item = (itemOrTier && typeof itemOrTier === 'object') ? itemOrTier : null;
      if (item && isMagicItem(item)) {
        if (item.category === 'components') return Math.min(missing, randBetween(1, Math.max(1, missing)));
        if (item.category === 'books') return Math.min(missing, randBetween(1, Math.max(1, Math.min(2, missing))));
        if (item.priceCp > 300000) return (rand(100) <= 5 && missing > 0) ? 1 : 0;
        if (item.priceCp > 150000) return Math.min(missing, 1);
        if (item.priceCp > 100000) return Math.min(missing, randBetween(1, 1));
        if (item.priceCp > 50000) return Math.min(missing, randBetween(1, 2));
        if (item.priceCp > 10000) return Math.min(missing, randBetween(1, 2));
        return Math.min(missing, randBetween(1, Math.max(1, missing)));
      }
      const t = magicTierRank(itemOrTier);
      if (t >= 5) return (rand(100) <= 10 && missing > 0) ? 1 : 0;
      if (t >= 4) return Math.min(missing, rand(1));
      if (t >= 3) return Math.min(missing, rand(2));
      if (t >= 2) return Math.min(missing, rand(3));
      return Math.min(missing, rand(Math.max(1, missing)));
    }
    const tier = itemOrTier;
    switch (tier) {
      case 'common':
        return Math.max(1, Math.floor(missing * (50 + rand(51) - 1) / 100));
      case 'uncommon':
        return Math.floor(missing * (25 + rand(36) - 1) / 100);
      case 'scarce':
        if (rand(100) > (store.settlement === 'city' ? 55 : 35)) return 0;
        return Math.max(1, Math.floor(missing * (20 + rand(21) - 1) / 100));
      case 'rare':
        if (rand(100) > (store.settlement === 'city' ? 25 : 10)) return 0;
        return 1;
      default:
        return Math.max(1, Math.floor(missing * 0.5));
    }
  };

  const restockStore = (store, mode) => {
    const kind = mode || 'both';
    ITEMS.forEach(item => {
      if (!localAllowed(store, item)) return;
      const monthly = needsMonthlyRestock(item);
      if (kind === 'minor' && monthly) return;
      if (kind === 'major' && !monthly) return;

      let target = targetQty(store, item);
      if (isHommletStore(store) && item.category === 'armor') {
        if (HOMMLET_ALWAYS_ARMOR.indexOf(item.key) !== -1) target = 1;
        else {
          const found = HOMMLET_CHANCE_ARMOR.find(a => a.key === item.key);
          target = (found && rand(100) <= found.chance) ? 1 : 0;
        }
      }
      const current = store.stock[item.key] || 0;
      if (current >= target) return;
      const add = restockAmount(target - current, item, store);
      if (add > 0) store.stock[item.key] = current + add;
    });

    ensureStockFloors(store, store.stock);
    syncMagicStockDetails(store, false);
    if (kind !== 'major') {
      store.trinkets = generateTrinkets(store);
      ensureStoreSpecials(store);
      ensureStockFloors(store, store.stock);
      store.lastMinorRestockDay = state[SCRIPT].day;
    } else {
      store.lastMajorRestockDay = state[SCRIPT].day;
    }
    store.lastRestockDay = state[SCRIPT].day;
  };

  const advanceDays = (days) => {
    const d = Math.max(0, parseInt(days || 0, 10) || 0);
    if (!d) return { days: 0, minor: 0, major: 0 };
    state[SCRIPT].day += d;
    let minor = 0;
    let major = 0;
    Object.keys(state[SCRIPT].stores).forEach(id => {
      const store = state[SCRIPT].stores[id];
      while ((state[SCRIPT].day - store.lastMinorRestockDay) >= 7) {
        restockStore(store, 'minor');
        minor++;
      }
      while ((state[SCRIPT].day - store.lastMajorRestockDay) >= 30) {
        restockStore(store, 'major');
        major++;
      }
    });
    return { days: d, minor, major };
  };

  const refreshAllNow = () => {
    let count = 0;
    Object.keys(state[SCRIPT].stores).forEach(id => {
      restockStore(state[SCRIPT].stores[id], 'both');
      count++;
    });
    return count;
  };

    const auditStore = (store) => {

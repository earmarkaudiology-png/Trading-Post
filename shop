  const parseStoreOpts = (parts) => {
    const opts = {};
    for (let i = 0; i < parts.length; i++) {
      const p = parts[i];
      if (p === '--type') opts.type = parts[++i];
      else if (p === '--size') opts.size = parts[++i];
      else if (p === '--settlement') opts.settlement = parts[++i];
      else if (p === '--focus') opts.focus = parts[++i];
      else if (p === '--name') opts.name = parts[++i];
      else if (p === '--mod') opts.baseModifier = parseInt(parts[++i], 10);
      else if (p === '--tags') opts.tags = (parts[++i] || '').split(',').map(s => slug(s));
    }
    if (opts.type && STORE_TYPES.indexOf(opts.type) === -1) delete opts.type;
    if (opts.size && SIZE_ORDER.indexOf(opts.size) === -1) delete opts.size;
    if (opts.settlement && SETTLEMENT_ORDER.indexOf(opts.settlement) === -1) delete opts.settlement;

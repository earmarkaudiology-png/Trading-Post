      resetCampaign();
      return gmInfo('Reset Campaign', [
        'All shop state has been reset.',
        'Day counter returned to 0.',
        'Generated stores, carts, orders, and cached horse traits were cleared.'
      ]);
    }
  };

    const resetCampaign = () => {
    state[SCRIPT] = {
      day: 0,
      stores: {},
      carts: {},
      orders: [],
      nextOrderId: 1,
      nextStoreId: 1,
      nextMagicStockId: 1,
      baselineHorseTraits: {}
    };
    stateInit();
  };

  const registerEventHandlers = () => on('chat:message', handleInput);
  const checkInstall = () => {
    stateInit();
    log(SCRIPT + ' v' + VERSION + ' ready.');
  };

  on('ready', () => {
    checkInstall();
    registerEventHandlers();
  });

  return { version: VERSION };
})();

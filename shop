      }
      if ((live - already) < 1) {
        return info(msg.playerid, 'Shop Error', ['That item is not currently in stock.', btn('Request Item', '!shop-request-search ' + store.id + ' "' + commandText(displayMagicItemName(item)) + '" 1', 110), btn('Back to Store', '!shop-view ' + store.id + ' ' + item.category + ' 1', 120)]);
      }

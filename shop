      if (item.tags.indexOf('water') !== -1 && store.tags.indexOf('port') === -1 && store.tags.indexOf('river') === -1) return 0;
      if (item.key.indexOf('ship_') === 0 || item.key.indexOf('galley_') === 0) {
        if (store.settlement !== 'city') return 0;
        min = 0; max = store.tags.indexOf('port') !== -1 ? sz : 0;
      } else if (item.key === 'wagon') {
        min = Math.max(0, sz - 1); max = sz + st - 1;
      } else if (item.key === 'cart') {
        min = sz; max = sz + st;
      } else {
        min = 0; max = sz + (store.tags.indexOf('port') !== -1 || store.tags.indexOf('river') !== -1 ? st : 0);
      }
    } else if (item.category === 'livestock') {
      if (item.tags.indexOf('military') !== -1) {
        min = 0; max = (store.tags.indexOf('military') !== -1 ? sz : Math.max(0, sz - 2));
      } else if (item.tags.indexOf('mount') !== -1) {
        min = Math.max(0, sz - 1); max = sz + st - 1;
      } else {
        min = sz; max = sz + st + 1;
      }
    } else {
      switch (item.tier) {
        case 'common':
          min = sz; max = (sz * 3) + st;
          break;
        case 'uncommon':
          min = Math.max(0, sz - 1); max = sz + st;
          break;
        case 'scarce':
          min = 0; max = Math.max(1, sz - 1 + Math.floor(st / 2));
          break;
        case 'rare':
          min = 0; max = Math.max(1, Math.floor((sz + st - 2) / 2));
          break;
        default:
          min = sz; max = (sz * 2) + st;
      }
    }
    if (store.focus === 'adventurer') {
      if (item.tags.indexOf('adventuring') !== -1 || item.category === 'weapons' || item.category === 'armor' || item.category === 'ammo') max += 2;
    }
    if (store.focus === 'traveler') {

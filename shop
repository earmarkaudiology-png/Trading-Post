  const stateInit = () => {
    if (!state[SCRIPT]) {
      state[SCRIPT] = {
        day: 0,
        stores: {},
        carts: {},
        nextStoreId: 1,
        baselineHorseTraits: {}
      };
    }
    if (!state[SCRIPT].baselineHorseTraits) state[SCRIPT].baselineHorseTraits = {};
    Object.keys(state[SCRIPT].stores || {}).forEach(id => {
      const s = state[SCRIPT].stores[id];
      if (typeof s.lastMinorRestockDay !== 'number') s.lastMinorRestockDay = (typeof s.lastRestockDay === 'number' ? s.lastRestockDay : state[SCRIPT].day);
      if (typeof s.lastMajorRestockDay !== 'number') s.lastMajorRestockDay = (typeof s.lastRestockDay === 'number' ? s.lastRestockDay : state[SCRIPT].day);
      if (typeof s.lastRestockDay !== 'number') s.lastRestockDay = state[SCRIPT].day;
    });
    if (!state[SCRIPT].stores.hommlet) {
      createStore({

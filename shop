    const martial = store.focus === 'adventurer' || store.tags.indexOf('military') !== -1;
    const frontier = store.tags.indexOf('frontier') !== -1 || store.tags.indexOf('remote') !== -1;

    if (store.type === 'trading_post') {
      if (key === 'padded') return Math.max(1, size);
      if (key === 'leather') return Math.max(1, size + (settle >= 3 ? 1 : 0));
      if (key === 'studded') return (size >= 2 || martial || frontier) ? 1 : 0;
      if (key === 'scale') return (size >= 3 || martial) ? 1 : 0;
      return 0;
    }

    if (store.type === 'outfitter') {
      if (key === 'padded') return Math.max(1, size + 1);
      if (key === 'leather') return Math.max(2, size + settle - 1);
      if (key === 'studded') return Math.max(1, size);
      if (key === 'scale') return size >= 2 ? Math.max(1, size - 1) : 0;
      if (key === 'ring_mail') return (size >= 2 || martial) ? 1 : 0;
      return 0;
    }

    if (store.type === 'smith') {
      if (key === 'padded' || key === 'leather') return size >= 2 ? 1 : 0;
      if (key === 'studded') return Math.max(1, size - 1);
      if (key === 'scale') return Math.max(1, size);
      if (key === 'ring_mail') return size >= 2 ? 1 : 0;
      if (key === 'chain') return (size >= 2 || settle >= 3) ? 1 : 0;
      return 0;
    }

